# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dep-agent

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@org.com
JIRA_API_TOKEN=your-jira-api-token

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_NOTIFICATION_CHANNEL=#pss-notifications

# Serviços internos (usados pelos MCP servers stdio)
MICRO_ACCOUNT_SERVICE_URL=http://micro-account-service
MOBILITY_SERVICE_URL=http://mobility-service
RISK_SERVICE_URL=http://risk-service

# ── MCP Servers ──────────────────────────────────────────────────────────────
# PAY e MOBILITY (stdio): sem config extra — o dep-agent spawna os processos.
# Os processos herdam todas as env vars acima automaticamente.

# RISK (HTTP Streamable): servidor externo
RISK_MCP_URL=http://localhost:3001/mcp
RISK_MCP_TOKEN=secret-compartilhado

# ── Configuração do servidor RISK (variáveis do processo RISK, não do dep-agent) ──
# DEP_AGENT_SECRET=secret-compartilhado   ← validado pelo middleware de auth do Risk MCP
# RISK_MCP_PORT=3001

# App
PORT=3000
NODE_ENV=development

# LangSmith — tracing automático de tools, agentes e nodes do grafo
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=dep-agent
